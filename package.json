{
  "name": "@rokob/nodedc",
  "version": "0.2.0",
  "description": "Native shared-dictionary compression for Node.js web servers.",
  "type": "module",
  "bin": {
    "nodedc-train-zstd": "./bin/nodedc-train-zstd.mjs",
    "nodedc-train-brotli": "./bin/nodedc-train-brotli.mjs"
  },
  "engines": {
    "node": ">=22.22.1"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "bin",
    "dist",
    "build/Release/*.node",
    "prebuilds",
    "vendor",
    "README.md",
    "LICENSE"
  ],
  "gypfile": true,
  "scripts": {
    "build": "npm run build:js && npm run build:native",
    "build:js": "tsc -p tsconfig.json",
    "build:native": "node-gyp rebuild",
    "clean": "rm -rf dist build prebuilds",
    "lint": "tsc -p tsconfig.json --noEmit",
    "build:prebuilts": "node ./scripts/build-prebuilts.mjs",
    "verify:prebuilts": "node ./scripts/verify-prebuilds.mjs",
    "train:zstd": "node ./bin/nodedc-train-zstd.mjs",
    "train:brotli": "node ./bin/nodedc-train-brotli.mjs",
    "rebuild": "npm run clean && npm run build",
    "test": "npm run test:unit",
    "test:unit": "node --import tsx --test test/unit/**/*.test.ts"
  },
  "keywords": [
    "brotli",
    "zstd",
    "compression",
    "dictionary",
    "node-addon"
  ],
  "author": "Andy Weiss <wvvwwvw@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rokob/nodedc.git"
  },
  "bugs": {
    "url": "https://github.com/rokob/nodedc/issues"
  },
  "homepage": "https://github.com/rokob/nodedc#readme",
  "dependencies": {
    "node-addon-api": "^8.2.1"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "node-gyp": "^11.4.2",
    "prebuildify": "^6.0.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3"
  }
}
